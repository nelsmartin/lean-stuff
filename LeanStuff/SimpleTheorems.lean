theorem add_zero (n : Nat) :  n + 0 = n := by
  sorry
theorem add_assoc (m n k : Nat) : n + m + k = n + (m + k) := by
  sorry

theorem zero_add (n : Nat): 0 + n = n := by
  sorry
theorem succ_add (n m : Nat) : n + 1 + m = (n + m) + 1 := by
  sorry

theorem add_succ (n m : Nat) : n + m + 1 = (n + m) + 1 := by
  sorry
